# cursor-trello-agent configuration
# Copy this to .env.local or .env and fill in the values

# Required — ngrok auth token for public tunnel
# Get yours free at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Optional — webhook server port (default: 3080)
TRELLO_PORT=3080

# Optional — Trello label that triggers the agent (default: critical)
TARGET_LABEL=critical
